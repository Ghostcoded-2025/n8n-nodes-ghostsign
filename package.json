{
	"name": "n8n-nodes-ghostsign",
	"version": "0.1.10",
	"description": "n8n community nodes for Ghostsign programmatic APIs hosted on Supabase Edge.",
	"license": "MIT",
	"homepage": "https://github.com/Ghostcoded-2025/n8n-nodes-ghostsign#readme",
	"keywords": ["n8n-community-node-package", "ghostsign", "signatures", "proposals"],
	"author": {
		"name": "tanner woodrum",
		"email": "tanner.woodrum1@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Ghostcoded-2025/n8n-nodes-ghostsign.git"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": ["dist"],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": ["dist/credentials/GhostsignApi.credentials.js"],
		"nodes": [
			"dist/nodes/Ghostsign/Ghostsign.node.js",
			"dist/nodes/GhostsignActions/GhostsignActions.node.js"
		]
	},
	"dependencies": {
		"n8n-workflow": "*"
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
